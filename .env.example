# Groq: https://console.groq.com/
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Qdrant: сетевой доступ или каталог на диске (укажите один вариант)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=tbank_faq
# Непустой путь — Qdrant в файловом режиме; QDRANT_HOST и QDRANT_PORT не используются
# QDRANT_PATH=./qdrant_storage

# Модель векторизации (идентификатор на Hugging Face)
EMBEDDING_MODEL=BAAI/bge-m3

# Число сегментов, попадающих в контекст ответа
RAG_FINAL_K=6
# Верхняя граница числа страниц при индексации (необязательно)
# RAG_MAX_PAGES=50
